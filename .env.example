# AgentCore OS example environment
# Copy the keys you need into `.env.local`, `.env.production`, or your process manager config.

# Next.js app port
PORT=3000

# Queue worker settings
OPENCLAW_APP_URL=http://127.0.0.1:3000
OPENCLAW_QUEUE_INTERVAL_MS=3000
OPENCLAW_QUEUE_SECRET=replace-with-a-long-random-secret

# Optional API hardening
# AGENTCORE_API_AUTH_TOKEN=replace-with-a-long-random-token
# AGENTCORE_ENABLE_RATE_LIMIT=1

# Optional examples for other parts of the app.
# Fill these only if you actively use the related features.

# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# AGENTCORE_ENGINE_BASE_URL=
# AGENTCORE_ENGINE_TOKEN=

# Desktop runtime examples
# AGENTCORE_RUNTIME_PROFILE=desktop_light
# AGENTCORE_RUNTIME_APP_URL=http://127.0.0.1:3000
# AGENTCORE_RUNTIME_URL=http://127.0.0.1:18789
# AGENTCORE_SIDECAR_API_URL=http://127.0.0.1:8080
# AGENTCORE_DIFY_BASE_URL=http://127.0.0.1:5001
# AGENTCORE_COMPOSE_PROJECT=agentcore-runtime
# LOBSTER_CORS_ALLOW_ORIGINS=tauri://localhost,http://tauri.localhost,http://localhost,https://tauri.localhost
# AGENTCORE_HEARTBEAT_PATH=/_agentcore/heartbeat
# AGENTCORE_HEARTBEAT_TIMEOUT_SECONDS=10
